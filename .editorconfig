root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cpp,hpp,h,cc,c}]
indent_size = 4
max_line_length = 120

[*.py]
indent_size = 4

[*.{yaml,yml,json,toml,md}]
indent_size = 2

[Makefile]
indent_style = tab
